APP_NAME=CampusMind
APP_ENV=development
FRONTEND_URL=http://localhost:3000
DATABASE_URL=sqlite:///./campusmind.db

UPLOAD_DIR=./storage/uploads

# ChromaDB Server 配置。如果没有启动 Chroma，开发模式会自动退回本地 JSON 向量索引。
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_SSL=false

# 推荐：Ajou/Mindlogic 网关聊天 + 本地兜底 embedding。
AI_PROVIDER=openai
EMBEDDING_PROVIDER=mock
OPENAI_BASE_URL=https://factchat-cloud.mindlogic.ai/v1/gateway
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 可选：如果你想改回本地 Ollama，把 AI_PROVIDER 和 EMBEDDING_PROVIDER 改成 ollama。
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# 开发时建议 true：没有配置 API Key 时仍可用兜底模式跑通流程。
ALLOW_MOCK_AI=true

JWT_SECRET_KEY=replace-this-secret-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
